{%- comment -%}
  Newsletter CTA - Award-Winning Design
  Dark theme, scroll-triggered animation, focus effects
{%- endcomment -%}

<section class="newsletter" id="newsletter-section">
  <div class="newsletter__background"></div>
  
  <div class="newsletter__container">
    <div class="newsletter__content">
      <h2 class="newsletter__title">Stay In The Loop</h2>
      <p class="newsletter__subtitle">
        Get exclusive fragrances, insider tips, and special offers delivered to your inbox.
      </p>
    </div>

    <form class="newsletter__form" method="post" action="/contact#contact_form">
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <div class="newsletter__input-wrapper">
        <input 
          type="email" 
          name="contact[email]" 
          placeholder="your@email.com"
          required
          class="newsletter__input"
          aria-label="Email address"
        >
        <button type="submit" class="newsletter__button">
          <span>Subscribe</span>
          <svg viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </div>

      <p class="newsletter__disclaimer">
        We respect your privacy. Unsubscribe at any time.
      </p>
    </form>
  </div>
</section>

<style>
.newsletter {
  position: relative;
  padding: 100px 20px;
  overflow: hidden;
}

.newsletter__background {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    #0a0a0a 0%,
    #1a1a2e 100%
  );
  z-index: -1;
}

.newsletter__background::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
  pointer-events: none;
}

.newsletter__container {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  color: #ffffff;
  opacity: 0;
  animation: fadeIn 1s ease-out 0.2s forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.newsletter__title {
  font-size: clamp(28px, 5vw, 48px);
  font-weight: 700;
  margin-bottom: 16px;
  letter-spacing: -1px;
}

.newsletter__subtitle {
  font-size: 16px;
  opacity: 0.85;
  margin-bottom: 40px;
  line-height: 1.6;
  font-weight: 300;
}

.newsletter__form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.newsletter__input-wrapper {
  display: flex;
  gap: 8px;
  background: rgba(255, 255, 255, 0.95);
  padding: 8px;
  border-radius: 4px;
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  transition: box-shadow 0.3s ease;
}

.newsletter__input-wrapper:focus-within {
  box-shadow: 0 10px 40px rgba(212, 175, 55, 0.4);
}

.newsletter__input {
  flex: 1;
  padding: 14px 16px;
  border: none;
  background: transparent;
  font-size: 14px;
  color: #0a0a0a;
  outline: none;
}

.newsletter__input::placeholder {
  color: #999;
}

.newsletter__button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  background: #d4af37;
  color: #0a0a0a;
  border: none;
  border-radius: 2px;
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform, box-shadow;
}

.newsletter__button:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(212, 175, 55, 0.4);
}

.newsletter__button:active {
  transform: translateY(0);
}

.newsletter__button svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.3s ease;
}

.newsletter__button:hover svg {
  transform: translateX(3px);
}

.newsletter__disclaimer {
  font-size: 12px;
  opacity: 0.7;
  margin-top: 12px;
}

@media (max-width: 768px) {
  .newsletter {
    padding: 60px 20px;
  }

  .newsletter__title {
    font-size: 28px;
  }

  .newsletter__subtitle {
    font-size: 14px;
    margin-bottom: 30px;
  }

  .newsletter__input-wrapper {
    flex-direction: column;
  }

  .newsletter__button {
    width: 100%;
    justify-content: center;
  }
}
</style>
