{%- comment -%}
  Award-Winning Hero Section
  Parallax background, animated text, smooth scroll effects
{%- endcomment -%}

<section class="hero" id="hero-section">
  <div class="hero__background">
    <div class="hero__parallax" style="background-image: url('https://images.unsplash.com/photo-1594783002909-a0b89fd374ff?w=1200&q=80')"></div>
    <div class="hero__overlay"></div>
  </div>
  
  <div class="hero__content">
    <div class="hero__text-wrapper">
      <h1 class="hero__title" data-splitting>
        Luxury Fragrance Redefined
      </h1>
      <p class="hero__subtitle" data-splitting>
        Discover the art of Arabian perfumery
      </p>
    </div>
    
    <button class="hero__cta" data-button>
      <span class="hero__cta-text">Explore Collection</span>
      <svg class="hero__cta-arrow" viewBox="0 0 24 24">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </button>
  </div>
</section>

<style>
:root {
  --color-dark: #0a0a0a;
  --color-gold: #d4af37;
  --color-white: #ffffff;
  --ease-out: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
}

.hero {
  position: relative;
  height: 100vh;
  min-height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--color-dark);
}

.hero__background {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero__parallax {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  will-change: transform;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(10, 10, 10, 0.7) 0%,
    rgba(26, 26, 46, 0.5) 100%
  );
  z-index: 1;
}

.hero__content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: var(--color-white);
  max-width: 800px;
  padding: 20px;
}

.hero__title {
  font-size: clamp(32px, 8vw, 72px);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 20px;
  letter-spacing: -1px;
}

.hero__subtitle {
  font-size: clamp(16px, 3vw, 28px);
  font-weight: 300;
  opacity: 0.9;
  margin-bottom: 60px;
  letter-spacing: 1px;
}

.hero__cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 16px 48px;
  background: var(--color-gold);
  color: var(--color-dark);
  border: none;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s var(--ease-in-out);
  will-change: transform, box-shadow;
}

.hero__cta:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(212, 175, 55, 0.3);
}

.hero__cta-arrow {
  width: 20px;
  height: 20px;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.3s var(--ease-out);
}

.hero__cta:hover .hero__cta-arrow {
  transform: translateX(4px);
}

@media (max-width: 768px) {
  .hero {
    min-height: 500px;
  }

  .hero__title {
    font-size: 32px;
  }

  .hero__subtitle {
    font-size: 18px;
  }

  .hero__cta {
    padding: 14px 32px;
    font-size: 12px;
  }
}
</style>

<script>
// Parallax effect on scroll
if (typeof window !== 'undefined') {
  const parallaxElement = document.querySelector('.hero__parallax');
  
  window.addEventListener('scroll', () => {
    const scrolled = window.pageYOffset;
    if (parallaxElement) {
      parallaxElement.style.transform = `translateY(${scrolled * 0.5}px)`;
    }
  });

  // Text animation on load
  const titleElement = document.querySelector('.hero__title');
  const subtitleElement = document.querySelector('.hero__subtitle');
  const ctaElement = document.querySelector('.hero__cta');

  if (titleElement) {
    titleElement.style.opacity = '0';
    titleElement.style.transform = 'translateY(30px)';
    setTimeout(() => {
      titleElement.style.transition = 'all 1s cubic-bezier(0.34, 1.56, 0.64, 1)';
      titleElement.style.opacity = '1';
      titleElement.style.transform = 'translateY(0)';
    }, 200);
  }

  if (subtitleElement) {
    subtitleElement.style.opacity = '0';
    subtitleElement.style.transform = 'translateY(30px)';
    setTimeout(() => {
      subtitleElement.style.transition = 'all 1s cubic-bezier(0.34, 1.56, 0.64, 1)';
      subtitleElement.style.opacity = '1';
      subtitleElement.style.transform = 'translateY(0)';
    }, 400);
  }

  if (ctaElement) {
    ctaElement.style.opacity = '0';
    ctaElement.style.transform = 'scale(0.9)';
    setTimeout(() => {
      ctaElement.style.transition = 'all 1s cubic-bezier(0.34, 1.56, 0.64, 1)';
      ctaElement.style.opacity = '1';
      ctaElement.style.transform = 'scale(1)';
    }, 600);
  }
}
</script>
