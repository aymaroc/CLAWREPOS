{%- comment -%}
  Featured Products Grid - Award-Winning Animations
  Hover effects, staggered reveals, smooth transitions
{%- endcomment -%}

<section class="featured-products">
  <div class="featured-products__container">
    <div class="featured-products__header">
      <h2 class="featured-products__title">Best Sellers</h2>
      <p class="featured-products__subtitle">Handpicked fragrances for the connoisseur</p>
    </div>

    <div class="featured-products__grid">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: 4 -%}
          <div class="product-card" style="animation-delay: {{ forloop.index0 | times: 100 }}ms">
            <div class="product-card__image-wrapper">
              {% if product.featured_image %}
                <img 
                  src="{{ product.featured_image | img_url: '400x400' }}" 
                  alt="{{ product.title }}"
                  class="product-card__image"
                  loading="lazy"
                >
              {% endif %}
              <div class="product-card__overlay"></div>
            </div>

            <div class="product-card__content">
              <h3 class="product-card__title">{{ product.title }}</h3>
              <div class="product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="product-card__price-original">{{ product.compare_at_price | money }}</span>
                  <span class="product-card__price-sale">{{ product.price | money }}</span>
                {%- else -%}
                  <span class="product-card__price-sale">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
              
              <a href="{{ product.url }}" class="product-card__cta">
                <span>Shop Now</span>
                <svg viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="featured-products__footer">
      <a href="/collections/all" class="featured-products__link">
        View All Products
        <svg viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
.featured-products {
  padding: 100px 20px;
  background: var(--color-white);
}

.featured-products__container {
  max-width: 1200px;
  margin: 0 auto;
}

.featured-products__header {
  text-align: center;
  margin-bottom: 80px;
}

.featured-products__title {
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 700;
  color: var(--color-dark);
  margin-bottom: 16px;
  position: relative;
  display: inline-block;
}

.featured-products__title::after {
  content: '';
  position: absolute;
  bottom: -12px;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 3px;
  background: var(--color-gold);
  border-radius: 2px;
}

.featured-products__subtitle {
  font-size: 16px;
  color: #666;
  margin-top: 24px;
}

.featured-products__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 40px;
  margin-bottom: 60px;
}

.product-card {
  display: flex;
  flex-direction: column;
  opacity: 0;
  animation: fadeInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  cursor: pointer;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.product-card__image-wrapper {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 8px;
  margin-bottom: 20px;
  background: #f5f5f5;
}

.product-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.product-card:hover .product-card__image {
  transform: scale(1.08) rotate(1deg);
}

.product-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(212, 175, 55, 0.2) 0%,
    rgba(212, 175, 55, 0) 100%
  );
  opacity: 0;
  transition: opacity 0.6s ease;
}

.product-card:hover .product-card__overlay {
  opacity: 1;
}

.product-card__content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-card__title {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-dark);
  margin-bottom: 12px;
  line-height: 1.4;
  transition: color 0.3s ease;
}

.product-card:hover .product-card__title {
  color: var(--color-gold);
}

.product-card__price {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-bottom: 20px;
  font-size: 14px;
  font-weight: 600;
}

.product-card__price-original {
  text-decoration: line-through;
  color: #999;
  opacity: 0;
  animation: slideUp 0.6s ease-out 0.3s forwards;
}

.product-card__price-sale {
  color: var(--color-gold);
  font-size: 16px;
  opacity: 0;
  animation: slideUp 0.6s ease-out 0.2s forwards;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.product-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: var(--color-gold);
  color: var(--color-dark);
  border: none;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  width: fit-content;
  opacity: 0;
  animation: slideUp 0.6s ease-out 0.4s forwards;
}

.product-card__cta:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 24px rgba(212, 175, 55, 0.3);
}

.product-card__cta svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.3s ease;
}

.product-card__cta:hover svg {
  transform: translateX(3px);
}

.featured-products__footer {
  text-align: center;
}

.featured-products__link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 32px;
  border: 2px solid var(--color-gold);
  color: var(--color-gold);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  border-radius: 4px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.featured-products__link:hover {
  background: var(--color-gold);
  color: var(--color-dark);
  transform: translateY(-3px);
}

.featured-products__link svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.3s ease;
}

.featured-products__link:hover svg {
  transform: translateX(4px);
}

@media (max-width: 768px) {
  .featured-products {
    padding: 60px 20px;
  }

  .featured-products__header {
    margin-bottom: 50px;
  }

  .featured-products__grid {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
  }

  .product-card__title {
    font-size: 14px;
  }

  .product-card__cta {
    padding: 10px 16px;
    font-size: 10px;
  }
}
</style>
