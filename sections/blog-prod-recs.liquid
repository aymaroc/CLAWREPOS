{%- comment -%}
  Blog Product Recommendations Section
  
  Intelligently suggests products based on blog post tags.
  Includes schema.org Product structured data for SEO.
  
  Settings:
  - num_products: Number of products to show (default: 4)
  - collection_handle: Limit to specific collection
  - show_title: Show section title
  - custom_title: Custom title text
  - show_shop_more: Show "Shop More" button
  - shop_more_text: Custom button text
{%- endcomment -%}

{% liquid
  assign num_products = section.settings.num_products | default: 4
  assign show_title = section.settings.show_title | default: true
  assign show_shop_more = section.settings.show_shop_more | default: true
  assign section_title = section.settings.custom_title | default: 'Shop Featured Products'
  assign shop_more_text = section.settings.shop_more_text | default: 'Shop More'
  assign collection_handle = section.settings.collection_handle
  
  # Initialize recommendations array
  assign recommended_products = '' | split: ','
  
  # Get blog/article tags
  assign article_tags = article.tags | join: ' '
  
  # Get all products and filter by tag relevance
  if collection_handle != blank
    assign search_collection = collections[collection_handle]
  else
    assign search_collection = collections.all
  endif
  
  # Build tag-based recommendation logic
  assign tag_matches = '' | split: ','
  
  for product in search_collection.products
    assign product_tags = product.tags | join: ' '
    assign match_count = 0
    
    for tag in article.tags
      if product_tags contains tag
        assign match_count = match_count | plus: 1
      endif
    endfor
    
    if match_count > 0
      assign tag_matches = tag_matches | push: product
    endif
  endfor
  
  # Sort by match count and take top N products
  assign recommended_products = tag_matches | reverse | slice: 0, num_products
  
  # Fallback: if no tag matches, show featured/popular products
  if recommended_products.size == 0
    assign recommended_products = search_collection.products | reverse | slice: 0, num_products
  endif
%}

<section class="blog-product-recommendations shopify-section" data-section-id="{{ section.id }}">
  <div class="container">
    
    {%- if show_title -%}
    <div class="halo-block-header text-center">
      <h2 class="halo-block-header__title">{{ section_title }}</h2>
    </div>
    {%- endif -%}
    
    <!-- Product Grid -->
    <div class="blog-recommendations-grid products-grid column-4" data-grid-size="4">
      {%- for product in recommended_products -%}
        <div class="blog-recommendations-grid__item product" data-product-id="{{ product.id }}">
          {% render 'blog-product-recommendation-card', product: product %}
        </div>
      {%- endfor -%}
    </div>
    
    <!-- Shop More Button -->
    {%- if show_shop_more and collection_handle != blank -%}
    <div class="blog-recommendations-footer">
      <a href="{{ collections[collection_handle].url }}" class="button button--primary blog-recommendations-cta">
        {{ shop_more_text }}
        <svg class="icon-arrow" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 20 10" width="20" height="10">
          <path stroke="currentColor" stroke-width="1.5" d="M14.3 0l-4.4 4.4L5.6 0"/>
        </svg>
      </a>
    </div>
    {%- endif -%}
  </div>
</section>

<!-- Structured Data (Schema.org) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "{{ section_title }}",
  "description": "Featured product recommendations for {{ article.title }}",
  "itemListElement": [
    {%- for product in recommended_products -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "item": {
          "@type": "Product",
          "name": "{{ product.title | escape }}",
          "url": "{{ shop.url }}{{ product.url }}",
          "description": "{{ product.description | strip_html | escape | truncatewords: 30 }}",
          "image": "{{ product.featured_image | img_url: '500x500' | replace: 'https://', 'https://' }}",
          "brand": {
            "@type": "Brand",
            "name": "{{ product.vendor | escape }}"
          },
          "offers": {
            "@type": "AggregateOffer",
            "priceCurrency": "{{ shop.currency }}",
            "lowPrice": "{{ product.price_min | money_without_currency | remove: ',' }}",
            "highPrice": "{{ product.price_max | money_without_currency | remove: ',' }}",
            "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
            "offerCount": {{ product.variants.size }}
          }
          {%- if product.metafields.judgeme.rating != blank -%}
          ,"aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "{{ product.metafields.judgeme.rating }}",
            "bestRating": "5",
            "worstRating": "1"
          }
          {%- endif -%}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>

<style>
.blog-product-recommendations {
  padding: 60px 0;
  background-color: var(--bg-white, #fff);
}

.blog-recommendations-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 30px;
  margin: 40px 0;
}

.blog-recommendations-grid__item {
  display: flex;
}

.blog-recommendations-footer {
  display: flex;
  justify-content: center;
  margin-top: 50px;
}

.blog-recommendations-cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  min-width: 200px;
  justify-content: center;
}

.blog-recommendations-cta .icon-arrow {
  width: 20px;
  height: 10px;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.3s ease;
}

.blog-recommendations-cta:hover .icon-arrow {
  transform: translateX(4px);
}

@media (max-width: 1024px) {
  .blog-recommendations-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
}

@media (max-width: 767px) {
  .blog-product-recommendations {
    padding: 40px 0;
  }

  .blog-recommendations-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .blog-recommendations-cta {
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Blog Product Recs",
  "settings": [
    {
      "type": "text",
      "id": "custom_title",
      "label": "Section Title",
      "default": "Shop Featured Products"
    },
    {
      "type": "range",
      "id": "num_products",
      "min": 1,
      "max": 8,
      "step": 1,
      "label": "Number of Products",
      "default": 4
    },
    {
      "type": "collection",
      "id": "collection_handle",
      "label": "Limit to Collection (optional)",
      "info": "Leave empty to search all products"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Section Title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shop_more",
      "label": "Show 'Shop More' Button",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_more_text",
      "label": "Shop More Button Text",
      "default": "Shop More"
    }
  ],
  "presets": [
    {
      "name": "Blog Product Recs"
    }
  ]
}
{% endschema %}
