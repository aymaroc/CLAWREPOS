{%- comment -%}
  Dubai Museum of the Future - Inspired Blog Template
  Futuristic, minimalist, premium aesthetic
  With integrated product recommendations
{%- endcomment -%}

<!-- Hero Section -->
<section class="blog-hero">
  <div class="blog-hero__container">
    <div class="blog-hero__content">
      <div class="blog-hero__meta">
        <span class="blog-hero__category">{{ article.blog.title }}</span>
        <span class="blog-hero__date">{{ article.published_at | date: "%b %d, %Y" }}</span>
      </div>
      
      <h1 class="blog-hero__title">{{ article.title }}</h1>
      
      <p class="blog-hero__excerpt">
        {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
      </p>
      
      <div class="blog-hero__author">
        <span class="author-label">By</span>
        <span class="author-name">{{ article.author }}</span>
        <span class="author-separator">•</span>
        <span class="reading-time">{{ article.content | number_of_words | divided_by: 200 | plus: 1 }} min read</span>
      </div>
    </div>

    <!-- Featured Image -->
    {% if article.image %}
    <div class="blog-hero__image">
      <img 
        src="{{ article.image | img_url: '1200x600' }}" 
        alt="{{ article.title }}"
        loading="eager"
      >
      <div class="blog-hero__overlay"></div>
    </div>
    {% endif %}
  </div>
</section>

<!-- Main Content -->
<article class="blog-article">
  <div class="blog-article__container">
    
    <!-- Article Body -->
    <div class="blog-article__body">
      {{ article.content }}
    </div>

    <!-- Article Footer -->
    <footer class="blog-article__footer">
      <div class="blog-article__tags">
        {% if article.tags.size > 0 %}
          <span class="tags-label">Tagged:</span>
          <div class="tags-list">
            {% for tag in article.tags %}
              <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="tag-badge">
                {{ tag }}
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="blog-article__share">
        <span class="share-label">Share</span>
        <div class="share-buttons">
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" 
             class="share-btn share-btn--facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M12 2c5.5 0 10 4.5 10 10s-4.5 10-10 10S2 17.5 2 12 6.5 2 12 2m0-2C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0z"/></svg>
          </a>
          <a href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ shop.url }}{{ article.url }}" 
             class="share-btn share-btn--twitter" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.12A9 9 0 0023 3z"/></svg>
          </a>
          <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&media={{ article.image | img_url: '1200x600' }}&description={{ article.title | url_encode }}" 
             class="share-btn share-btn--pinterest" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M12 2c5.5 0 10 4.5 10 10s-4.5 10-10 10S2 17.5 2 12 6.5 2 12 2z"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </div>
</article>

<!-- Related Articles -->
<section class="blog-related">
  <div class="blog-related__container">
    <h2 class="blog-related__title">Continue Reading</h2>
    <div class="blog-related__grid">
      {% for related in blog.articles limit: 3 %}
        {% unless related.handle == article.handle %}
          <article class="blog-card">
            {% if related.image %}
              <div class="blog-card__image">
                <img src="{{ related.image | img_url: '400x300' }}" alt="{{ related.title }}">
                <div class="blog-card__overlay"></div>
              </div>
            {% endif %}
            
            <div class="blog-card__content">
              <p class="blog-card__date">{{ related.published_at | date: "%b %d, %Y" }}</p>
              <h3 class="blog-card__title">
                <a href="{{ related.url }}">{{ related.title }}</a>
              </h3>
              <p class="blog-card__excerpt">{{ related.excerpt_or_content | strip_html | truncatewords: 15 }}</p>
              <a href="{{ related.url }}" class="blog-card__link">Read More →</a>
            </div>
          </article>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Newsletter Signup -->
<section class="blog-newsletter">
  <div class="blog-newsletter__container">
    <div class="blog-newsletter__content">
      <h2 class="blog-newsletter__title">Stay Updated</h2>
      <p class="blog-newsletter__text">Get curated fragrance insights, guides, and exclusive offers delivered to your inbox.</p>
    </div>
    
    <form class="blog-newsletter__form" method="post" action="/contact#contact_form">
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="form-group">
        <input 
          type="email" 
          name="contact[email]" 
          placeholder="Enter your email"
          required
          class="form-input"
        >
        <button type="submit" class="form-submit">Subscribe</button>
      </div>
    </form>
  </div>
</section>

<!-- Styles -->
<style>
:root {
  --color-white: #ffffff;
  --color-black: #000000;
  --color-dark: #0a0a0a;
  --color-light-gray: #f5f5f5;
  --color-medium-gray: #e0e0e0;
  --color-gold: #d4af37;
  --duration-default: 0.3s;
  --duration-long: 0.6s;
  --ease: cubic-bezier(0.4, 0.0, 0.2, 1);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  background: var(--color-white);
  color: var(--color-dark);
  line-height: 1.6;
}

/* Hero */
.blog-hero {
  position: relative;
  min-height: 600px;
  padding: 80px 20px;
  background: linear-gradient(135deg, var(--color-dark) 0%, #1a1a2e 100%);
  overflow: hidden;
}

.blog-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
  pointer-events: none;
}

.blog-hero__container {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.blog-hero__content { color: var(--color-white); }

.blog-hero__meta {
  display: flex;
  gap: 16px;
  margin-bottom: 24px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  opacity: 0.8;
}

.blog-hero__category {
  padding: 6px 12px;
  background: rgba(212, 175, 55, 0.2);
  border: 1px solid rgba(212, 175, 55, 0.4);
  border-radius: 20px;
  color: var(--color-gold);
}

.blog-hero__title {
  font-size: clamp(28px, 5vw, 56px);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 20px;
  letter-spacing: -1px;
  animation: fadeInUp 0.8s var(--ease);
}

.blog-hero__excerpt {
  font-size: 18px;
  opacity: 0.9;
  margin-bottom: 32px;
  max-width: 500px;
  line-height: 1.8;
  animation: fadeInUp 0.8s var(--ease) 0.1s both;
}

.blog-hero__author {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  opacity: 0.75;
  animation: fadeInUp 0.8s var(--ease) 0.2s both;
}

.blog-hero__image {
  position: relative;
  aspect-ratio: 1;
  border-radius: 8px;
  overflow: hidden;
  animation: fadeInScale 0.8s var(--ease) 0.2s both;
}

.blog-hero__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.blog-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, transparent 100%);
}

/* Article */
.blog-article { padding: 80px 20px; }

.blog-article__container { max-width: 820px; margin: 0 auto; }

.blog-article__body {
  font-size: 16px;
  line-height: 1.8;
  color: var(--color-dark);
}

.blog-article__body h2 {
  font-size: 28px;
  font-weight: 700;
  margin: 48px 0 20px;
  padding-top: 40px;
}

.blog-article__body a {
  color: var(--color-gold);
  border-bottom: 1px solid var(--color-gold);
  text-decoration: none;
}

.blog-article__body img {
  max-width: 100%;
  margin: 32px 0;
  border-radius: 4px;
}

.blog-article__footer {
  margin-top: 60px;
  padding-top: 40px;
  border-top: 1px solid var(--color-medium-gray);
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
}

.tags-list {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.tag-badge {
  padding: 6px 14px;
  background: var(--color-light-gray);
  border: 1px solid var(--color-medium-gray);
  border-radius: 20px;
  font-size: 12px;
  text-decoration: none;
  transition: all var(--duration-default);
}

.tag-badge:hover {
  background: var(--color-gold);
  color: var(--color-white);
}

.share-buttons {
  display: flex;
  gap: 8px;
}

.share-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--color-light-gray);
  transition: all var(--duration-default);
}

.share-btn svg {
  width: 16px;
  height: 16px;
  fill: var(--color-dark);
}

.share-btn:hover {
  background: var(--color-gold);
  transform: translateY(-2px);
}

.share-btn:hover svg { fill: var(--color-white); }

/* Related */
.blog-related {
  padding: 80px 20px;
  background: var(--color-light-gray);
}

.blog-related__container { max-width: 1200px; margin: 0 auto; }

.blog-related__title {
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 48px;
  text-align: center;
  position: relative;
}

.blog-related__title::after {
  content: '';
  position: absolute;
  bottom: -12px;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 3px;
  background: var(--color-gold);
  border-radius: 2px;
}

.blog-related__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 32px;
  margin-top: 48px;
}

.blog-card {
  background: var(--color-white);
  border-radius: 4px;
  overflow: hidden;
  transition: all var(--duration-long) var(--ease);
}

.blog-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
}

.blog-card__image {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
}

.blog-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--duration-long) var(--ease);
}

.blog-card:hover .blog-card__image img { transform: scale(1.05); }

.blog-card__content { padding: 24px; }

.blog-card__date {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: 8px;
}

.blog-card__title a {
  color: var(--color-dark);
  border: none;
  font-size: 18px;
  font-weight: 600;
}

.blog-card__title a:hover { color: var(--color-gold); }

.blog-card__excerpt {
  font-size: 14px;
  color: #666;
  margin-bottom: 16px;
}

.blog-card__link {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-gold);
  text-decoration: none;
  border: none;
  display: inline-block;
}

.blog-card__link:hover { transform: translateX(4px); }

/* Newsletter */
.blog-newsletter {
  padding: 80px 20px;
  background: linear-gradient(135deg, var(--color-dark) 0%, #1a1a2e 100%);
  color: var(--color-white);
}

.blog-newsletter__container { max-width: 820px; margin: 0 auto; text-align: center; }

.blog-newsletter__title {
  font-size: 40px;
  font-weight: 700;
  margin-bottom: 16px;
}

.blog-newsletter__text {
  font-size: 16px;
  opacity: 0.9;
  margin-bottom: 32px;
}

.blog-newsletter__form {
  display: flex;
  gap: 12px;
  max-width: 500px;
  margin: 0 auto;
}

.form-group {
  display: flex;
  gap: 12px;
  width: 100%;
}

.form-input {
  flex: 1;
  padding: 14px 16px;
  border: none;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.95);
  font-size: 14px;
}

.form-input:focus {
  outline: none;
  background: var(--color-white);
  box-shadow: 0 0 0 2px var(--color-gold);
}

.form-submit {
  padding: 14px 32px;
  background: var(--color-gold);
  color: var(--color-dark);
  border: none;
  border-radius: 4px;
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  transition: all var(--duration-default);
  white-space: nowrap;
}

.form-submit:hover {
  background: #e5c158;
  transform: translateY(-2px);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@media (max-width: 768px) {
  .blog-hero__container { grid-template-columns: 1fr; gap: 40px; }
  .blog-hero { min-height: 400px; padding: 60px 20px; }
  .blog-hero__title { font-size: 28px; }
  .blog-article__footer { grid-template-columns: 1fr; gap: 24px; }
  .blog-newsletter__form { flex-direction: column; }
  .form-group { flex-direction: column; }
  .form-submit { width: 100%; }
  .blog-related__grid { grid-template-columns: 1fr; gap: 24px; }
}
</style>
